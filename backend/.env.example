# Database
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=pwa_varejo

# JWT
JWT_SECRET=pwa-varejo-secret-key-change-in-production-min-256-bits
JWT_EXPIRATION=24h

# Server
PORT=3001
NODE_ENV=development

# CORS — origens permitidas (separadas por vírgula)
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# Branding (exibido no frontend via VITE_STORE_NAME também)
STORE_NAME=Loja Teste

# Web Push (notificações) — gere o par com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@loja.com
